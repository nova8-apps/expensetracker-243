{
  "expo": {
    "name": "nova8-app",
    "slug": "nova8-app",
    "scheme": "nova8app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/[REPLACE_AFTER_FIRST_BUILD]",
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses your camera to capture receipts and documents.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to let you select images.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "1",
      "privacyPolicyUrl": "https://nova8.dev/privacy/243",
      "usesAppleSignIn": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "minSdkVersion": 24,
            "enableMinifyInReleaseBuilds": true
          },
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ],
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "extra": {
      "privacyPolicyUrl": "https://nova8.dev/privacy/243"
    }
  }
}